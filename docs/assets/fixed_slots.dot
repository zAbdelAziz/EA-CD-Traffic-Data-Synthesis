
digraph G {
  graph [layout=neato, bgcolor="white", overlap=false, splines=true, pad="0.25"];
  node [shape=box, style="rounded,filled", fillcolor="#f7f7f7", color="#333333", fontname="Helvetica", fontsize=12, margin="0.10,0.07"];
  edge [color="#777777", arrowsize=0.65, fontname="Helvetica", fontsize=10];
  ego [pos="0,0!", label="EGO\nvx, vy", fillcolor="#eef5ff"];
  LF [pos="-1.7,1.7!", label="LF\ndx, dy, p"];
  F [pos="0,2.0!", label="F\ndx, dy, p"];
  RF [pos="1.7,1.7!", label="RF\ndx, dy, p"];
  LR [pos="-1.7,-1.7!", label="LR\ndx, dy, p"];
  R [pos="0,-2.0!", label="R\ndx, dy, p"];
  RR [pos="1.7,-1.7!", label="RR\ndx, dy, p"];
  LF -> ego [label="relative"];
  F -> ego;
  RF -> ego;
  LR -> ego;
  R -> ego;
  RR -> ego;
}
